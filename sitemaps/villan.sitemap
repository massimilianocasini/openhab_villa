        }
        // Eleonora
        Text label="Eleonora  [%.1f °C]" item=Termoumidostato13T icon="temperature"
             labelcolor=[FeedBRele13==1="green", FeedBRele13==0="red"] {
            Text  item=Termoumidostato13T  label="Temperatura [%.1f °C]"
            Text  item=Termoumidostato13U  label="Umidità [%.1f %%]"
            Text  item=FeedBRele13         label="Stato [MAP(feedbackr.map):%s]"  valuecolor=[1="green", 0="red"]
