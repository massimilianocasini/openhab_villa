            Setpoint item=Termoumidostato9S label="Setpoint [%.1f °C]" minValue=10 maxValue=30 step=1
            Switch item=ProxyAttTermo9 mappings=[ON="Attiva"]   visibility=[ProxyWatingAttTermo9==3]
            Switch item=ProxyAttTermo9 mappings=[ON="Disattiva"] visibility=[ProxyWatingAttTermo9==4]
        }
        // Corridoio
        Text label="Corridoio  [%.1f °C]" item=Termoumidostato10T icon="temperature"
             labelcolor=[FeedBRele10==1="green", FeedBRele10==0="red"] {
            Text  item=Termoumidostato10T  label="Temperatura [%.1f °C]"
            Text  item=Termoumidostato10U  label="Umidità [%.1f %%]"
            Text  item=FeedBRele10         label="Stato [MAP(feedbackr.map):%s]"  valuecolor=[1="green", 0="red"]
            Text  item=StatoRele10         label="Rele [MAP(statorele.map):%s]"   valuecolor=[1="green", 0="red"]
            Setpoint item=Termoumidostato10S label="Setpoint [%.1f °C]" minValue=10 maxValue=30 step=1
            Switch item=ProxyAttTermo10 mappings=[ON="Attiva"]   visibility=[ProxyWatingAttTermo10==3]
            Switch item=ProxyAttTermo10 mappings=[ON="Disattiva"] visibility=[ProxyWatingAttTermo10==4]
        }
        // Arianna
        Text label="Arianna  [%.1f °C]" item=Termoumidostato11T icon="temperature"
             labelcolor=[FeedBRele11==1="green", FeedBRele11==0="red"] {
            Text  item=Termoumidostato11T  label="Temperatura [%.1f °C]"
            Text  item=Termoumidostato11U  label="Umidità [%.1f %%]"
            Text  item=FeedBRele11         label="Stato [MAP(feedbackr.map):%s]"  valuecolor=[1="green", 0="red"]
