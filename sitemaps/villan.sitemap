        // App. verde
        Text label="App. verde  [%.1f °C]" item=Termoumidostato9T icon="temperature"
             labelcolor=[FeedBRele9==1="green", FeedBRele9==0="red"] {
            Text  item=Termoumidostato9T  label="Temperatura [%.1f °C]"
            Text  item=Termoumidostato9U  label="Umidità [%.1f %%]"
            Text  item=FeedBRele9         label="Stato [MAP(feedbackr.map):%s]"  valuecolor=[1="green", 0="red"]
