            Switch item=ProxyAttTermo11 mappings=[ON="Disattiva"] visibility=[ProxyWatingAttTermo11==4]
        }
        // Giolo
        Text label="Giolo  [%.1f °C]" item=Termoumidostato12T icon="temperature"
             labelcolor=[FeedBRele12==1="green", FeedBRele12==0="red"] {
            Text  item=Termoumidostato12T  label="Temperatura [%.1f °C]"
            Text  item=Termoumidostato12U  label="Umidità [%.1f %%]"
