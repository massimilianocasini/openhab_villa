    // ── Setpoint ACS ────────────────────────────────────────
    Frame label="💧 Acqua sanitaria" {
        Setpoint item=Set_temp_standard_condition_ACS   label="Setpoint ACS [%.1f °C]" minValue=40 maxValue=90 step=1
        Text     item=TempContrACS                      label="T. attuale ACS [%.1f °C]"
    }

    // ── Pompe ────────────────────────────────────────────────
    Frame label="⚙️ Pompe" {
        Text item=PompaRicircolo      label="Ricircolo [MAP(pomp.map):%s]"      valuecolor=[1="green", 0="red"]
        Text item=PompaPianoInterrato label="Piano Interrato [MAP(pomp.map):%s]" valuecolor=[1="green", 0="red"]
        Text item=PompaPianoTerra     label="Piano Terra [MAP(pomp.map):%s]"     valuecolor=[1="green", 0="red"]
        Text item=PompaPianoPrimo     label="Piano Primo [MAP(pomp.map):%s]"     valuecolor=[1="green", 0="red"]
        Text item=PompaTermosifoni    label="Termosifoni [MAP(pomp.map):%s]"     valuecolor=[1="green", 0="red"]
        Text item=PompaRilancio       label="Rilancio [MAP(pomp.map):%s]"        valuecolor=[1="green", 0="red"]
