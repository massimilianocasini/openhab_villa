rule "Invia messaggio a BOT per device IP persa"
    when
        Member of gNetwork changed
    then
    val host = triggeringItem
    val telegramActions = getActions("telegram","telegram:telegramBot:Telegram_Bot")
    val hostLabel = host.label ?: host.name
    if (host.state == ON) {
        telegramActions.sendTelegram("Host " + hostLabel + " connesso in rete VILLA")
    }
    else {
        telegramActions.sendTelegram("Host " + hostLabel + " perso dalla rete VILLA !!!!")
    }
end
