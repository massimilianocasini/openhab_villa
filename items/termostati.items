Number StatoRele1                       "Relay Trmst Biliardo [MAP(statorele.map):%s]" <settings> (gTermoumidostatoBiliardo, gStatoRele) ["Status"] { channel="modbus:data:termo_bridge:termo_poller03:ReleTht1:number" }
Number FeedBRele1                       "Trmst Biliardo [MAP(feedbackr.map):%s]" <settings> (gTermoumidostatoBiliardo, gFeedBRele) { channel="modbus:data:termo_bridge:termo_poller03:FReleTht1:number" }
Number ONTht1                           "Trmst ON Biliardo" <settings> (gTermoumidostatoBiliardo, gONTht) { channel="modbus:data:termo_bridge:termo_poller03:OnTht1:number" }
Number OFFTht1                          "Trmst OFF Biliardo" <settings> (gTermoumidostatoBiliardo, gOFFTht) { channel="modbus:data:termo_bridge:termo_poller03:OffTht1:number" }
Switch ProxyAttTermo1                   "Att./Dis. Trmst Biliardo" <settings> (gProxyAtt)
Number ProxyWatingAttTermo1             "Proxy Waiting Trmst Biliardo" (gProxyWating)
String ProxyTempAttTermo1               "Attendi ...."
String Riepilogo1                       "Riepilogo Biliardo PI" (gRiepilogo)

