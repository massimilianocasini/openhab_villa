// ============================================================
// STATO FASCE ZONE
// ============================================================
Number StatoFZ1 "Piano Interrato [MAP(zone.map):%s]" <settings> (GLocaleTecnico) { channel="modbus:data:termo_bridge:termo_poller09:Sfz1:number" }
