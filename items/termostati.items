// ============================================================
// PDC - Pompa di Calore
// ============================================================
Number:Temperature TempAccImpianto          "T.accumulo impianto [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TAccImp:number" }
Number:Temperature TempContrACS             "T.controllo ACS [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TContrACS:number" }
Number:Temperature TempMandGeo              "T.acqua uscita GEO [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TMandGEO:number" }
Number:Temperature TempRitGeo               "T.acqua ingresso GEO [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TRitGEO:number" }
Number:Temperature TempUscitaScambCircImp   "T.acqua uscita Scambiatore Circuito impianto [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TUscitaaAquaScambiatoreCI:number" }
Number:Temperature TempIngressoScambCircPrim "T.acqua ingresso Scambiatore Circuito primario [%.1f C°]" <temperature> (GLocaleTecnico, gHVAC, gInfluxdb) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:pdc_bridge:pdc_poller01:TIngressoAcquaScambiatoreCP:number" }

Number Set_temp_standard_condition_chiller      "SetP T.StCond.(Chiller)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) { channel="modbus:data:pdc_bridge:pdc_poller02:SetTinStCC:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="27"] }
Number Set_temp_standard_condition_heatPump     "SetP T.StCond.(Heat Pump)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) { channel="modbus:data:pdc_bridge:pdc_poller02:SetTinStCHP:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="27"] }
Number Set_temp_standard_condition_ACS          "SetP T.ACS StCond.(PDC)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) ["Setpoint","Temperature"] { channel="modbus:data:pdc_bridge:pdc_poller02:SetTACStCPDC:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="90"] }
Number Set_temp_energySave_condition_chiller    "SetP T.EnerSaveCond.(Chiller)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) { channel="modbus:data:pdc_bridge:pdc_poller02:SetTinSaCC:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="27"] }
Number Set_temp_energySave_condition_heatPump   "SetP T.EnerSaveCond.(Heat Pump)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) { channel="modbus:data:pdc_bridge:pdc_poller02:SetTinSaCHP:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="27"] }
Number Set_temp_energySave_condition_ACS        "SetP T.ACS EnerSaveCond.(PDC)[%.1f °C]" <temperature> (GLocaleTecnico, gHVAC) ["Setpoint","Temperature"] { channel="modbus:data:pdc_bridge:pdc_poller02:SetTACSESCPDC:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="90"] }

Number StatoPDC     "Stato PDC [MAP(statopdc.map):%s]" <poweroutlet> (GLocaleTecnico) { channel="modbus:data:pdc_bridge:pdc_poller03:StatoPDC:number" }
Number ModalitaPDC  "Modalita  [MAP(modalitapdc.map):%s]" <settings> (GLocaleTecnico) { channel="modbus:data:pdc_bridge:pdc_poller03:ModoPDC:number" }

