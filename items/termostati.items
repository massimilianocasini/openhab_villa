// ============================================================
// TERMOSTATO 1 - Biliardo PI
// ============================================================
Number:Temperature Termoumidostato1T    "T.Biliardo PI [%.1f °C]" <temperature> (gTermoumidostatoBiliardo, gTemperature, gTempT) ["Measurement","Temperature"] {unit="°C", channel="modbus:data:termo_bridge:termo_poller04:Tht1t:number" }
Number Termoumidostato1U                "U.Biliardo PI [%.1f %%]" <humidity> (gTermoumidostatoBiliardo, gTemperature) ["Measurement","Humidity"] { channel="modbus:data:termo_bridge:termo_poller04:Tht1u:number" }
Number Termoumidostato1S                "SP Biliardo PI [%.1f °C]" <temperature> (gTermoumidostatoBiliardo, gSetpoint) ["Setpoint","Temperature"] { channel="modbus:data:termo_bridge:termo_poller08:Tht1s:number", stateDescription="" [pattern="%.1f °C"], listWidget="oh-stepper-item", widget="oh-stepper-card" [step="1", min="21", max="27"] }
Number AttTestina1                      "Att. testina Elettrotermica Biliardo [MAP(testina.map):%s]" <settings> (gTermoumidostatoBiliardo) ["Status"] { channel="modbus:data:termo_bridge:termo_poller03:TestTht1:number" }
